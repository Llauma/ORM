@@ -0,0 +1,26 @@
+package com.lauma.client.render;
+
+import net.minecraft.item.ItemStack;
+
+/**
+ * Thread-local holder for the ItemStack currently being rendered.
+ * Set by MixinItemRenderer at the entry of renderItem; read by
+ * MixinLayerRenderState when wrapping the BakedModel for that layer.
+ */
+public final class RenderContext {
+    private static final ThreadLocal<ItemStack> CURRENT = new ThreadLocal<>();
+
+    private RenderContext() {}
+
+    public static void push(ItemStack stack) {
+        CURRENT.set(stack);
+    }
+
+    public static ItemStack current() {
+        return CURRENT.get();
+    }
+
+    public static void pop() {
+        CURRENT.remove();
+    }
+}
